# Kopieer naar `.env` en vul je echte waarden in. `.env` staat in .gitignore.
# Zie docs/shopify_env.md
#
# NOOIT echte wachtwoorden of tokens in .env.example committen — alleen placeholders.

# Verplicht voor Shopify Admin API (REST + GraphQL uploads)
# Admin API access token uit Shopify Admin (Settings → Apps → Develop apps)
SHOPIFY_ACCESS_TOKEN=

# Shop (meestal defaults)
SHOPIFY_SHOP_DOMAIN=ktm-shop-nl.myshopify.com
SHOPIFY_SHOP_SLUG=ktm-shop-nl

# Admin API-versie: geldt voor GraphQL (o.a. fileupload in image_manager) én REST
# (o.a. variant/product-cache in modules/shopify_client.py). Zie docs/shopify_env.md
SHOPIFY_ADMIN_API_VERSION=2024-10

# CDN-basis voor Image Src in product-CSV (Settings → Files of een bestaande CDN-URL uit je shop)
SHOPIFY_CDN_FILES_BASE_URL=https://cdn.shopify.com/s/files/1/0511/7820/9461/files/

# KTM-export-XML (main.py, YMM/metafields): default = input/CBEXPDN_KTM-DN*.xml (één bestand), of bij meerdere het nieuwste op schijf
# KTM_XML_FILE=CBEXPDN_KTM-DN-3009-0.xml
# KTM_XML_FILE=input/mijn_export.xml

# 0150-prijs-CSV voor main.py: default = input/0150_35_Z1_EUR_EN_csv.csv; anders eerste *0150*.csv
# KTM_0150_CSV=andere_naam.csv

# Logging (main.py): naar stdout + standaard output/logs/ktm_etl_<timestamp>.log
# KTM_LOG_LEVEL=INFO
# Eigen logpad i.p.v. output/logs/…:
# KTM_LOG_FILE=/pad/naar/etl.log

# Afbeeldingen (main.py): geen dubbele uploads — cache wordt vertrouwd; vóór upload optioneel
# GraphQL files-zoektocht (vereist read_files op het Admin-token). Zet op 0 om over te slaan.
# KTM_IMAGE_SHOPIFY_FILE_LOOKUP=1

# Variant-metafield voor ETA-sync (scripts/shopify_sync_eta_from_0150.py) — namespace = die in Admin
# onder Settings → Custom data → Variants (bijv. global.inventory_policy_eta_date, niet custom.*)
# SHOPIFY_VARIANT_ETA_METAFIELD_NAMESPACE=global
# SHOPIFY_VARIANT_ETA_METAFIELD_KEY=inventory_policy_eta_date

# Optioneel: product-metafield met fits_on JSON voor modules/shopify_supabase_mirror.py → shopify_ymm
# SHOPIFY_PRODUCT_FITS_ON_NAMESPACE=custom
# SHOPIFY_PRODUCT_FITS_ON_KEY=fits_on

# Test: mirror alleen eerste N product-pagina's (~40 producten per pagina); leeg = volledige catalogus
# KTM_SHOPIFY_MIRROR_MAX_PAGES=2

# ------------------------------
# FTP/SFTP → input/ (scripts/fetch_input_sftp.py)
# ------------------------------
# Voor FileZilla-instelling "FTP - File Transfer Protocol" + "Use explicit FTP over TLS":
# KTM_TRANSFER_PROTOCOL=ftps
# Voor SFTP (SSH): KTM_TRANSFER_PROTOCOL=sftp
# Voor plain FTP (niet aanbevolen): KTM_TRANSFER_PROTOCOL=ftp
# KTM_TRANSFER_PROTOCOL=ftps
# KTM_SFTP_HOST=ftp1.ktm.com
# KTM_SFTP_PORT=21
# Gebruikersnaam exact zoals je leverancier aangeeft (soms met | of andere tekens):
# KTM_SFTP_USER=jouw_gebruiker
# KTM_SFTP_PASSWORD=jouw_wachtwoord
# Alleen voor SFTP: sleutel i.p.v. wachtwoord:
# KTM_SFTP_KEY_PATH=/Users/jij/.ssh/id_ed25519
# KTM_SFTP_KEY_PASSPHRASE=
# Remote map op de server (root = /)
# KTM_SFTP_REMOTE_DIR=/
# KTM_SFTP_LOCAL_DIR=downloads/ftp
# Alleen deze bestanden ophalen (komma’s; overschrijft “alles downloaden”):
# KTM_SFTP_FILES=XML_Export_PIM_HQV_International.zip,XML_Export_PIM_KTM_International.zip,XML_Export_PIM_WP_International.zip,0140_35_Z1_EUR_EN_csv.csv,0910_35_Z1_EUR_EN_csv.csv,0150_35_Z1_EUR_EN_csv.csv
# Anders: glob-patroon op alle bestanden in de remote map (als KTM_SFTP_FILES leeg is):
# KTM_SFTP_PATTERN=*.xml

# Prepare stap: staging -> input (scripts/prepare_input_from_ftp.py)
# KTM_PREPARE_FILES=XML_Export_PIM_HQV_International.zip,XML_Export_PIM_KTM_International.zip,XML_Export_PIM_WP_International.zip,0140_35_Z1_EUR_EN_csv.csv,0910_35_Z1_EUR_EN_csv.csv,0150_35_Z1_EUR_EN_csv.csv

# FTPS robuustheid (grote downloads)
# KTM_FTP_TIMEOUT_SEC=120
# KTM_FTP_RETRIES=6
# KTM_FTP_RETRY_SLEEP_SEC=3
# KTM_FTP_BLOCKSIZE=1048576
